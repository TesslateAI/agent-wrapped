# ===========================================
# Agent Wrapped — Environment Variables
# ===========================================
# Copy this file to .env.local and fill in values
# cp .env.example .env.local

# -------------------------------------------
# App
# -------------------------------------------
NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_APP_NAME=Agent Wrapped

# -------------------------------------------
# Optional: LLM-Powered Insights (Phase 3)
# Used for richer personality analysis
# App is fully functional without these
# -------------------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=

# -------------------------------------------
# Optional: Analytics
# -------------------------------------------
NEXT_PUBLIC_POSTHOG_KEY=
NEXT_PUBLIC_POSTHOG_HOST=https://us.i.posthog.com

# -------------------------------------------
# Optional: Image Generation for Share Cards
# (if using server-side OG image generation)
# -------------------------------------------
# No keys needed — uses @vercel/og or html-to-image client-side

# -------------------------------------------
# Optional: Rate Limiting (if adding API routes)
# -------------------------------------------
UPSTASH_REDIS_REST_URL=
UPSTASH_REDIS_REST_TOKEN=
